---
layout: base.njk
title: "Contact Us &mdash; Still Me Project"
description: "Get in touch with the Still Me Project. Questions, partnerships, or stories to share — reach out."
---


    <!-- ==========================================
         PAGE HERO
         ========================================== -->
    <section class="page-hero">
      <div class="container">
        <h1>Get in Touch</h1>
        <p class="page-hero-subtitle">Questions, partnerships, or stories to share &mdash; reach out.</p>
      </div>
    </section>


    <!-- ==========================================
         CONTACT FORM & INFO
         ========================================== -->
    <section class="section" id="contact-form-section" aria-labelledby="contact-form-heading">
      <div class="container">

        <div class="split">

          <!-- Left: Contact Form -->
          <div class="split__text">
            <h2 id="contact-form-heading">Send Us a Message</h2>
            <p>
              Whether you have a question, want to partner with us, or have a story to share, use the form below. We respond within two business days.
            </p>

            <form class="contact-form" action="#" method="post">
              <fieldset>
                <legend class="visually-hidden">Contact form</legend>

              <div class="form-group">
                <label for="contact-name" class="form-label">Name</label>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  class="form-input"
                  placeholder="Your full name"
                  autocomplete="name"
                  required
                  aria-required="true"
                >
              </div>

              <div class="form-group">
                <label for="contact-email" class="form-label">Email</label>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  class="form-input"
                  placeholder="you@example.com"
                  autocomplete="email"
                  required
                  aria-required="true"
                >
              </div>

              <div class="form-group">
                <label for="contact-subject" class="form-label">Subject</label>
                <input
                  type="text"
                  id="contact-subject"
                  name="subject"
                  class="form-input"
                  placeholder="What is this about?"
                >
              </div>

              <div class="form-group">
                <label for="contact-message" class="form-label">Message</label>
                <textarea
                  id="contact-message"
                  name="message"
                  rows="6"
                  class="form-textarea"
                  placeholder="Tell us what is on your mind..."
                  required
                  aria-required="true"
                ></textarea>
              </div>

              <button type="submit" class="btn btn-primary">Send Message</button>

              </fieldset>
            </form>
          </div>

          <!-- Right: Contact Info -->
          <div class="split__image">
            <div class="contact-info-panel">

              <h3>Contact Information</h3>

              <div class="contact-info__group">
                <p class="contact-info__label">Email</p>
                <a href="mailto:hello@stillmeproject.org">hello@stillmeproject.org</a>
              </div>

              <div class="contact-info__group">
                <p class="contact-info__label">Phone</p>
                <a href="tel:+15551234567">(555) 123-4567</a>
              </div>

              <div class="contact-info__group">
                <p class="contact-info__label">Address</p>
                <address>
                  123 Compassion Lane<br>
                  Suite 200<br>
                  Portland, OR 97201
                </address>
              </div>

              <div class="contact-info__group">
                <p class="contact-info__label">Follow Us</p>
                <p class="social-links">
                  <a href="#" aria-label="Still Me Project on Facebook">Facebook</a>
                  <a href="#" aria-label="Still Me Project on Instagram">Instagram</a>
                  <a href="#" aria-label="Still Me Project on LinkedIn">LinkedIn</a>
                </p>
              </div>

            </div>
          </div>

        </div>

      </div>
    </section>


    <!-- ==========================================
         FAQ SECTION
         ========================================== -->
    <section class="section section--cream" id="faq" aria-labelledby="faq-heading">
      <div class="container">

        <div class="section-header">
          <span class="section-label">Common Questions</span>
          <h2 id="faq-heading">Frequently Asked Questions</h2>
        </div>

        <div class="content-width">

          <!-- FAQ 1 -->
          <div class="faq-item">
            <h3>What is the Still Me Project?</h3>
            <p>
              A nonprofit that funds cognitive decline research, develops practical technology for families, and provides caregiver education and support.
            </p>
          </div>

          <!-- FAQ 2 -->
          <div class="faq-item">
            <h3>Who do you serve?</h3>
            <p>
              Individuals with cognitive decline, their families, and their caregivers. Our research also serves clinicians and the broader care community.
            </p>
          </div>

          <!-- FAQ 3 -->
          <div class="faq-item">
            <h3>How is the organization funded?</h3>
            <p>
              Through individual donations, grants, and institutional partnerships. We are a registered 501(c)(3) nonprofit.
            </p>
          </div>

          <!-- FAQ 4 -->
          <div class="faq-item">
            <h3>How can I get involved?</h3>
            <p>
              Donate, volunteer, or share our work. Visit our <a href="/get-involved/">Get Involved</a> page for details.
            </p>
          </div>

        </div>

      </div>
    </section>


    <!-- ==========================================
         CALL TO ACTION
         ========================================== -->
    <section class="section cta-section" id="contact-cta" aria-labelledby="contact-cta-heading">
      <div class="container">
        <h2 id="contact-cta-heading">Let&rsquo;s Start a Conversation</h2>
        <p>
          Whether you are looking for support, want to partner with us, or simply want to
          learn more, we are here. Reach out anytime.
        </p>
        <a href="mailto:hello@stillmeproject.org" class="btn btn-gold btn-lg">Email Us</a>
      </div>
    </section>
