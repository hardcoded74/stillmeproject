        <li><a href="/stories/" class="mobile-nav__link{% if page.url == '/stories/' %} active{% endif %}">Stories</a></li>
        <li><a href="/support/" class="mobile-nav__link{% if page.url == '/support/' %} active{% endif %}">Support the Work</a></li>
        <li><a href="/contact/" class="mobile-nav__link{% if page.url == '/contact/' %} active{% endif %}">Contact</a></li>
      </ul>
    </nav>
    <div class="mobile-nav__cta">
      <a href="/support/" class="btn btn-gold">Support the Work</a>
    </div>
  </div>
