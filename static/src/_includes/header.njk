  <!-- Skip to Content (visually hidden until keyboard focus) -->
  <a href="#main-content" class="visually-hidden-skip">Skip to main content</a>

  <!-- ============================================
       MASTHEAD — Logo + Connection Collage
       ============================================ -->
  <div class="masthead" role="banner">
    <div class="masthead__inner">

      <!-- Logo (left side) -->
      <a href="/" class="masthead__logo" aria-label="Still Me Project — Home">
        <img src="/images/smp-logo-full.png" alt="Still Me Project">
      </a>

      <!-- Connection Collage (right side, fades in from white) -->
      <div class="masthead__collage" aria-hidden="true">
        <div class="masthead__collage-images">
          <img src="/images/collage-2.jpg" alt="" class="masthead__collage-img">
          <img src="/images/collage-4.jpg" alt="" class="masthead__collage-img">
          <img src="/images/collage-1.jpg" alt="" class="masthead__collage-img">
          <img src="/images/collage-3.jpg" alt="" class="masthead__collage-img">
        </div>
        <!-- Gradient mask: fades collage into white on the left edge -->
        <div class="masthead__collage-mask"></div>
      </div>

    </div>
  </div>

  <!-- ============================================
       NAVIGATION ROW (sticky)
       ============================================ -->
  <header class="site-header">
    <div class="container site-header__inner">

      <!-- Desktop Navigation -->
      <nav class="site-nav" aria-label="Primary navigation">
        <ul class="site-nav__list">
          <li><a href="/" class="site-nav__link{% if page.url == '/' %} active{% endif %}">Home</a></li>
          <li><a href="/about/" class="site-nav__link{% if page.url == '/about/' %} active{% endif %}">About</a></li>
          <li><a href="/our-approach/" class="site-nav__link{% if page.url == '/our-approach/' %} active{% endif %}">Our Approach</a></li>
          <li><a href="/stories/" class="site-nav__link{% if page.url == '/stories/' %} active{% endif %}">Stories</a></li>
          <li><a href="/support/" class="site-nav__link{% if page.url == '/support/' %} active{% endif %}">Support the Work</a></li>
          <li><a href="/contact/" class="site-nav__link{% if page.url == '/contact/' %} active{% endif %}">Contact</a></li>
        </ul>
      </nav>

      <!-- Mobile Hamburger -->
      <button class="nav-toggle" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-nav">
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </button>

    </div>
  </header>

  <!-- Mobile Navigation Overlay -->
  <div class="mobile-nav__overlay" id="mobile-nav-overlay"></div>
  <div class="mobile-nav" id="mobile-nav" role="dialog" aria-modal="true" aria-label="Navigation menu">
    <button class="mobile-nav__close" aria-label="Close navigation menu">&times;</button>
    <nav aria-label="Mobile navigation">
      <ul class="mobile-nav__list">
