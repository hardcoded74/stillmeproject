<?php

/**
 * @file
 * Theme functions and preprocess hooks for the Still Me theme.
 */

/**
 * Implements hook_preprocess_page().
 */
function stillme_preprocess_page(array &$variables): void {
  // Provide the current year for copyright notices in templates.
  $variables['current_year'] = date('Y');
}

/**
 * Implements hook_preprocess_node().
 */
function stillme_preprocess_node(array &$variables): void {
  // Add a view mode class to the node wrapper for targeted styling.
  $view_mode = $variables['view_mode'] ?? 'full';
  $variables['attributes']['class'][] = 'node--view-mode-' . \Drupal\Component\Utility\Html::getClass($view_mode);
}

/**
 * Implements hook_theme_suggestions_page_alter().
 */
function stillme_theme_suggestions_page_alter(array &$suggestions, array $variables): void {
  // Add template suggestions based on the current content type.
  $route_match = \Drupal::routeMatch();
  $node = $route_match->getParameter('node');

  if ($node && is_object($node)) {
    $content_type = $node->bundle();
    $suggestions[] = 'page__node__' . $content_type;
  }
}

/**
 * Implements hook_preprocess_block().
 */
function stillme_preprocess_block(array &$variables): void {
  // Add block bundle classes for targeted styling.
  if (!empty($variables['elements']['#plugin_id'])) {
    $plugin_id = $variables['elements']['#plugin_id'];
    $variables['attributes']['class'][] = 'block--' . \Drupal\Component\Utility\Html::getClass($plugin_id);
  }

  // Add bundle class for custom block types.
  if (isset($variables['elements']['content']['#block_content'])) {
    $block_content = $variables['elements']['content']['#block_content'];
    $bundle = $block_content->bundle();
    $variables['attributes']['class'][] = 'block--bundle-' . \Drupal\Component\Utility\Html::getClass($bundle);
  }
}
