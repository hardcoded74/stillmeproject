{#
/**
 * @file
 * Still Me Project - Base region template.
 *
 * Available variables:
 * - content: The content for this region.
 * - attributes: HTML attributes for the region wrapper.
 *
 * @see template_preprocess_region()
 */
#}

{% if content %}
  <div{{ attributes.addClass('region', 'region--' ~ region|clean_class) }}>
    {{ content }}
  </div>
{% endif %}
