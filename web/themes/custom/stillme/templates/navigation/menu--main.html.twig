{#
/**
 * @file
 * Still Me Project - Main navigation menu template.
 *
 * Renders the primary navigation with proper .main-nav, .nav-list,
 * and .nav-link classes. Supports one level of dropdown children.
 *
 * Available variables:
 * - items: A nested list of menu items.
 * - attributes: HTML attributes for the menu wrapper.
 *
 * @see template_preprocess_menu()
 */
#}

{% import _self as menus %}

{#
  Macro to render menu items recursively.
  Only renders up to 2 levels for the main nav.
#}
{% macro menu_links(items, attributes, menu_level) %}
  {% import _self as menus %}

  {% if items %}
    {% if menu_level == 0 %}
      <ul{{ attributes.addClass('main-nav', 'nav-list') }} role="menubar">
    {% else %}
      <ul class="nav-list nav-list--sub" role="menu">
    {% endif %}

    {% for item in items %}
      {%
        set item_classes = [
          'nav-list__item',
          item.is_expanded ? 'nav-list__item--expanded',
          item.is_collapsed ? 'nav-list__item--collapsed',
          item.in_active_trail ? 'nav-list__item--active-trail',
        ]
      %}
      <li{{ item.attributes.addClass(item_classes) }} role="none">
        {#
          Set link attributes for accessibility.
        #}
        {% set link_attrs = {
          'class': ['nav-link', item.in_active_trail ? 'nav-link--active'],
          'role': 'menuitem',
        } %}

        {% if item.below %}
          {% set link_attrs = link_attrs|merge({'aria-expanded': 'false', 'aria-haspopup': 'true'}) %}
        {% endif %}

        {{ link(item.title, item.url, link_attrs) }}

        {% if item.below %}
          {{ menus.menu_links(item.below, attributes, menu_level + 1) }}
        {% endif %}
      </li>
    {% endfor %}

    </ul>
  {% endif %}
{% endmacro %}

{{ menus.menu_links(items, attributes, 0) }}
