{#
/**
 * @file
 * Still Me Project - Main page template.
 *
 * Standalone page template for the bootstrap5 base theme.
 * Does NOT extend the base theme template.
 *
 * Available variables:
 * - page: The full page render array with all regions.
 * - is_front: Whether this is the front page.
 * - b5_top_container: Container class from theme settings.
 * - b5_navbar_schema: Navbar color scheme from theme settings.
 * - b5_navbar_bg_schema: Navbar background scheme from theme settings.
 * - b5_footer_schema: Footer color scheme from theme settings.
 * - b5_footer_bg_schema: Footer background scheme from theme settings.
 *
 * @see template_preprocess_page()
 * @see stillme_bootstrap_preprocess_page()
 */
#}

{# ==================== HEADER ==================== #}
{% if page.header %}
  <header role="banner">
    {{ page.header }}
  </header>
{% endif %}

{# ==================== NAVBAR ==================== #}
<nav class="navbar navbar-expand-lg navbar-{{ b5_navbar_schema }} bg-{{ b5_navbar_bg_schema }} sticky-top" aria-label="{{ 'Main navigation'|t }}">
  <div class="{{ b5_top_container }}">

    {# Site branding #}
    {% if page.nav_branding %}
      {{ page.nav_branding }}
    {% endif %}

    {# Mobile toggler button #}
    <button class="navbar-toggler" type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarMain"
            aria-controls="navbarMain"
            aria-expanded="false"
            aria-label="{{ 'Toggle navigation'|t }}">
      <span class="navbar-toggler-icon"></span>
    </button>

    {# Collapsible navigation #}
    <div class="collapse navbar-collapse" id="navbarMain">
      {% if page.nav_main %}
        {{ page.nav_main }}
      {% endif %}
      {% if page.nav_additional %}
        {{ page.nav_additional }}
      {% endif %}
    </div>

  </div>
</nav>

{# ==================== BREADCRUMB ==================== #}
{% if page.breadcrumb %}
  <div class="{{ b5_top_container }}">
    {{ page.breadcrumb }}
  </div>
{% endif %}

{# ==================== MAIN CONTENT ==================== #}
<main role="main" id="main-content">
  <a id="main-content-anchor" tabindex="-1"></a>

  <div class="{{ b5_top_container }}">
    <div class="row">

      {# Sidebar first #}
      {% if page.sidebar_first %}
        <div class="col-lg-3 order-lg-1">
          <aside class="sidebar sidebar-first" role="complementary" aria-label="{{ 'Sidebar first'|t }}">
            {{ page.sidebar_first }}
          </aside>
        </div>
      {% endif %}

      {# Main content area #}
      <div class="{{ page.sidebar_first and page.sidebar_second ? 'col-lg-6' : (page.sidebar_first or page.sidebar_second ? 'col-lg-9' : 'col-lg-12') }} order-lg-2">
        {{ page.content }}
      </div>

      {# Sidebar second #}
      {% if page.sidebar_second %}
        <div class="col-lg-3 order-lg-3">
          <aside class="sidebar sidebar-second" role="complementary" aria-label="{{ 'Sidebar second'|t }}">
            {{ page.sidebar_second }}
          </aside>
        </div>
      {% endif %}

    </div>
  </div>

</main>

{# ==================== FOOTER ==================== #}
<footer class="site-footer bg-{{ b5_footer_bg_schema }} text-{{ b5_footer_schema }}" role="contentinfo" aria-label="{{ 'Site footer'|t }}">

  {# -- Main footer columns -- #}
  <div class="{{ b5_top_container }} py-5">
    <div class="row">

      {# Column 1: Site name & description #}
      <div class="col-lg-3 mb-4 mb-lg-0">
        <h5 class="site-footer__heading">{{ site_name ? site_name : 'Still Me Project'|t }}</h5>
        <p class="small text-light opacity-75">
          {{ 'Honoring identity, strengthening connection, and preserving dignity for individuals and families navigating memory loss.'|t }}
        </p>
      </div>

      {# Column 2: Quick Links / Footer region #}
      <div class="col-lg-3 mb-4 mb-lg-0">
        {% if page.footer %}
          {{ page.footer }}
        {% else %}
          <h5 class="site-footer__heading">{{ 'Quick Links'|t }}</h5>
          <ul class="list-unstyled">
            <li><a href="/" class="text-light text-decoration-none">{{ 'Home'|t }}</a></li>
            <li><a href="/about" class="text-light text-decoration-none">{{ 'About Us'|t }}</a></li>
            <li><a href="/programs" class="text-light text-decoration-none">{{ 'Programs'|t }}</a></li>
            <li><a href="/stories" class="text-light text-decoration-none">{{ 'Stories'|t }}</a></li>
            <li><a href="/contact" class="text-light text-decoration-none">{{ 'Contact'|t }}</a></li>
          </ul>
        {% endif %}
      </div>

      {# Column 3: Contact info #}
      <div class="col-lg-3 mb-4 mb-lg-0">
        <h5 class="site-footer__heading">{{ 'Contact Us'|t }}</h5>
        <ul class="list-unstyled small text-light opacity-75">
          <li>{{ 'Email: info@stillmeproject.org'|t }}</li>
          <li>{{ 'Phone: (555) 123-4567'|t }}</li>
          <li>{{ 'Address: 123 Hope Street'|t }}</li>
        </ul>
      </div>

      {# Column 4: Stay Connected #}
      <div class="col-lg-3">
        <h5 class="site-footer__heading">{{ 'Stay Connected'|t }}</h5>
        <p class="small text-light opacity-75">
          {{ 'Subscribe to our newsletter for updates on programs, stories of transformation, and ways to get involved.'|t }}
        </p>
      </div>

    </div>
  </div>

  {# -- Footer bottom bar -- #}
  <div class="site-footer__bottom">
    <div class="{{ b5_top_container }} py-3">
      <div class="row align-items-center">
        <div class="col-md-6">
          <p class="mb-0 small">&copy; {{ 'now'|date('Y') }} {{ 'Still Me Project. All rights reserved.'|t }}</p>
        </div>
        <div class="col-md-6 text-md-end">
        </div>
      </div>
    </div>
  </div>

</footer>
