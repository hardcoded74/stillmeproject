{#
/**
 * @file
 * Still Me Project - Story node template (full view).
 *
 * Displays a story with a hero/banner image, title, meta information,
 * body content, related stories, and a CTA section.
 *
 * Available variables:
 * - node: The full node entity.
 * - content: All field render arrays.
 * - label: The title of the node.
 * - url: The canonical URL for this node.
 *
 * @see template_preprocess_node()
 */
#}

{%
  set classes = [
    'node',
    'node--type-' ~ node.bundle|clean_class,
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  ]
%}

<article{{ attributes.addClass(classes) }}>

  {# -- Hero / Banner image -- #}
  {% if content.field_feature_image|render|trim is not empty %}
    <div class="stillme-page-hero stillme-page-hero--image" aria-label="{{ 'Story banner'|t }}">
      <div class="stillme-page-hero__image">
        {{ content.field_feature_image }}
      </div>
    </div>
  {% endif %}

  {# -- Story content -- #}
  <div class="container">
    <div class="content-width py-5">

      {# Title #}
      {{ title_prefix }}
      <h1{{ title_attributes.addClass('mb-3') }} style="font-family: 'Lora', serif;">
        {{ label }}
      </h1>
      {{ title_suffix }}

      {# Meta line: date and category #}
      <div class="text-muted mb-4 pb-3 border-bottom" aria-label="{{ 'Story details'|t }}">
        {% if content.field_publish_date|render|trim is not empty %}
          <span class="me-3">
            <i class="bi bi-calendar3" aria-hidden="true"></i>
            {{ content.field_publish_date }}
          </span>
        {% endif %}
        {% if content.field_category|render|trim is not empty %}
          <span>
            <i class="bi bi-tag" aria-hidden="true"></i>
            {{ content.field_category }}
          </span>
        {% endif %}
      </div>

      {# Body content #}
      <div{{ content_attributes.addClass('node__content') }}>
        {{ content|without('field_feature_image', 'field_publish_date', 'field_category') }}
      </div>

    </div>
  </div>

  {# -- Related stories placeholder -- #}
  <section class="stillme-section bg-light" aria-label="{{ 'Related stories'|t }}">
    <div class="container">
      <h2 class="stillme-section__heading text-center mb-4">{{ 'Related Stories'|t }}</h2>
      <div class="row">
        {# Placeholder cards - replaced by Views block in production #}
        {% for i in 1..3 %}
          <div class="col-md-4 mb-4">
            <div class="card stillme-story-card h-100">
              <div class="ratio ratio-16x9">
                <div class="bg-secondary d-flex align-items-center justify-content-center">
                  <span class="text-white-50">{{ 'Story image'|t }}</span>
                </div>
              </div>
              <div class="card-body">
                <h3 class="card-title h5">{{ 'Lorem ipsum dolor sit amet'|t }}</h3>
                <p class="card-text small text-muted">{{ 'Consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore.'|t }}</p>
                <a href="#" class="btn btn-outline-primary btn-sm">{{ 'Read more'|t }}</a>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# -- CTA section -- #}
  <section class="stillme-cta stillme-cta--teal text-center py-5" aria-label="{{ 'Call to action'|t }}">
    <div class="container">
      <h2 class="text-white mb-3">{{ 'Every Story Matters'|t }}</h2>
      <p class="text-white lead mb-4">{{ 'Help us continue sharing stories of transformation and hope.'|t }}</p>
      <a href="/donate" class="btn btn-warning btn-lg me-2">{{ 'Donate Now'|t }}</a>
      <a href="/stories" class="btn btn-outline-light btn-lg">{{ 'Read More Stories'|t }}</a>
    </div>
  </section>

</article>
