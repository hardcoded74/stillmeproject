{#
/**
 * @file
 * Still Me Project - Story teaser (card) template.
 *
 * Displays a story as a Bootstrap card for listing pages.
 * Uses the .stillme-story-card class for custom styling.
 *
 * Available variables:
 * - node: The full node entity.
 * - content: All field render arrays.
 * - label: The title of the node.
 * - url: The canonical URL for this node.
 *
 * @see template_preprocess_node()
 */
#}

{%
  set classes = [
    'node',
    'node--type-' ~ node.bundle|clean_class,
    'node--view-mode-teaser',
    not node.isPublished() ? 'node--unpublished',
  ]
%}

<article{{ attributes.addClass(classes) }}>
  <div class="card stillme-story-card h-100">

    {# Card image with 16:9 aspect ratio #}
    <div class="ratio ratio-16x9">
      {% if content.field_feature_image|render|trim is not empty %}
        <div class="card-img-top-wrapper">
          {{ content.field_feature_image }}
        </div>
      {% else %}
        {# Fallback placeholder image #}
        <div class="bg-secondary d-flex align-items-center justify-content-center card-img-top">
          <span class="text-white-50">{{ 'Story image'|t }}</span>
        </div>
      {% endif %}
    </div>

    {# Card body #}
    <div class="card-body d-flex flex-column">

      {# Date #}
      {% if content.field_publish_date|render|trim is not empty %}
        <div class="text-muted small mb-2">
          {{ content.field_publish_date }}
        </div>
      {% endif %}

      {# Title as link #}
      {{ title_prefix }}
      <h3{{ title_attributes.addClass('card-title', 'h5') }}>
        <a href="{{ url }}" rel="bookmark" class="text-decoration-none">
          {{ label }}
        </a>
      </h3>
      {{ title_suffix }}

      {# Excerpt / body teaser #}
      {% if content.body|render|trim is not empty %}
        <p class="card-text text-muted small flex-grow-1">
          {{ content.body }}
        </p>
      {% else %}
        <p class="card-text text-muted small flex-grow-1">
          {{ 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.'|t }}
        </p>
      {% endif %}

      {# Read more link #}
      <div class="mt-auto">
        <a href="{{ url }}" class="btn btn-outline-primary btn-sm" aria-label="{{ 'Read more about'|t }} {{ label }}">
          {{ 'Read more'|t }}
          <i class="bi bi-arrow-right ms-1" aria-hidden="true"></i>
        </a>
      </div>

    </div>

  </div>
</article>
