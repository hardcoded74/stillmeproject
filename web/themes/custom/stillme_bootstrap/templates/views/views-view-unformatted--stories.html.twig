{#
/**
 * @file
 * Still Me Project - Stories view (unformatted) template.
 *
 * Renders story items in a responsive Bootstrap grid:
 * 2 columns on medium screens, 3 columns on large screens.
 *
 * Available variables:
 * - title: The title of this group of rows (if applicable).
 * - rows: A list of row items, each containing:
 *   - content: The row content (rendered node teaser).
 *   - attributes: HTML attributes for the row.
 *
 * @see template_preprocess_views_view_unformatted()
 */
#}

{% if title %}
  <h3>{{ title }}</h3>
{% endif %}

<div class="row">
  {% for row in rows %}
    <div class="col-md-6 col-lg-4 mb-4">
      {%- if row.attributes -%}
        <div{{ row.attributes }}>
          {{ row.content }}
        </div>
      {%- else -%}
        {{ row.content }}
      {%- endif -%}
    </div>
  {% endfor %}
</div>
