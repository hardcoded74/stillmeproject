<?php

/**
 * @file
 * Still Me Bootstrap sub-theme preprocess functions.
 */

/**
 * Implements hook_preprocess_page().
 */
function stillme_bootstrap_preprocess_page(&$variables) {
  // Add current year for copyright.
  $variables['current_year'] = date('Y');

  // Add site logo to the template.
  $variables['site_logo'] = theme_get_setting('logo.url');
  $variables['site_name'] = \Drupal::config('system.site')->get('name');
}

/**
 * Implements hook_preprocess_node().
 */
function stillme_bootstrap_preprocess_node(&$variables) {
  // Add view mode class.
  $variables['attributes']['class'][] = 'node--view-mode-' . $variables['view_mode'];
}

/**
 * Implements hook_theme_suggestions_page_alter().
 */
function stillme_bootstrap_theme_suggestions_page_alter(array &$suggestions, array $variables) {
  // Add content type based page suggestions.
  $node = \Drupal::routeMatch()->getParameter('node');
  if ($node && is_object($node)) {
    $suggestions[] = 'page__' . $node->bundle();
  }
}

/**
 * Implements hook_preprocess_block().
 */
function stillme_bootstrap_preprocess_block(&$variables) {
  // Add block bundle class for custom block types.
  if (isset($variables['elements']['#plugin_id'])) {
    $plugin_id = $variables['elements']['#plugin_id'];
    if (strpos($plugin_id, 'block_content:') === 0) {
      $block = $variables['elements']['content']['#block_content'] ?? NULL;
      if ($block) {
        $variables['attributes']['class'][] = 'block--type-' . $block->bundle();
      }
    }
  }
}
