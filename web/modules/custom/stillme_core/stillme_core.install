<?php

/**
 * @file
 * Install, update, and uninstall functions for the Still Me Core module.
 */

/**
 * Implements hook_install().
 */
function stillme_core_install() {
  // Update the existing Basic Page form display to include our custom fields.
  $form_display = \Drupal::entityTypeManager()
    ->getStorage('entity_form_display')
    ->load('node.page.default');

  if ($form_display) {
    $form_display->setComponent('field_hero_heading', [
      'type' => 'string_textfield',
      'weight' => 2,
      'region' => 'content',
      'settings' => [
        'size' => 60,
        'placeholder' => 'Override hero heading (optional)',
      ],
    ]);
    $form_display->setComponent('field_intro_text', [
      'type' => 'text_textarea',
      'weight' => 3,
      'region' => 'content',
      'settings' => [
        'rows' => 5,
        'placeholder' => '',
      ],
    ]);
    $form_display->setComponent('field_feature_image', [
      'type' => 'media_library_widget',
      'weight' => 4,
      'region' => 'content',
      'settings' => [
        'media_types' => [],
      ],
    ]);
    $form_display->setComponent('field_cta_block', [
      'type' => 'text_textarea',
      'weight' => 8,
      'region' => 'content',
      'settings' => [
        'rows' => 5,
        'placeholder' => '',
      ],
    ]);
    $form_display->save();
  }

  // Update the existing Basic Page view display to include our custom fields.
  $view_display = \Drupal::entityTypeManager()
    ->getStorage('entity_view_display')
    ->load('node.page.default');

  if ($view_display) {
    $view_display->setComponent('field_hero_heading', [
      'type' => 'string',
      'weight' => 1,
      'label' => 'hidden',
    ]);
    $view_display->setComponent('field_intro_text', [
      'type' => 'text_default',
      'weight' => 2,
      'label' => 'hidden',
    ]);
    $view_display->setComponent('field_feature_image', [
      'type' => 'entity_reference_entity_view',
      'weight' => 0,
      'label' => 'hidden',
    ]);
    $view_display->setComponent('field_cta_block', [
      'type' => 'text_default',
      'weight' => 10,
      'label' => 'hidden',
    ]);
    $view_display->save();
  }

  \Drupal::messenger()->addStatus(t('Still Me Core module has been installed. Content types, block types, and views are now available.'));
  \Drupal::messenger()->addStatus(t('Please configure your homepage layout using Layout Builder and place the custom block types as needed.'));
}

/**
 * Implements hook_uninstall().
 */
function stillme_core_uninstall() {
  \Drupal::messenger()->addStatus(t('Still Me Core module has been uninstalled.'));
}
